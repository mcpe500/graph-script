{
  "name": "graphscript",
  "version": "0.2.0",
  "description": "Composable Visual Scripting for Charts, Diagrams, Algorithms, and 3D",
  "main": "dist/cli.js",
  "module": "dist/browser/graphscript.esm.js",
  "browser": "dist/browser/graphscript.esm.js",
  "types": "dist/browser/browser.d.ts",
  "bin": {
    "graphscript": "dist/cli.js"
  },
  "exports": {
    ".": {
      "node": {
        "import": "./dist/cli.js",
        "require": "./dist/cli.js"
      },
      "default": {
        "import": "./dist/browser/graphscript.esm.js",
        "require": "./dist/browser/graphscript.js"
      }
    }
  },
  "files": [
    "dist/",
    "src/"
  ],
  "scripts": {
    "build": "tsc",
    "build:browser": "rollup -c rollup.config.mjs",
    "build:all": "tsc && rollup -c rollup.config.mjs",
    "build:browser:min": "rollup -c rollup.config.mjs && npx terser dist/browser/graphscript.esm.js -o dist/browser/graphscript.esm.min.js --source-map && npx terser dist/browser/graphscript.js -o dist/browser/graphscript.min.js --source-map",
    "watch": "tsc --watch",
    "test": "jest",
    "check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "check:max-lines": "ts-node scripts/check-max-lines.ts",
    "guard:quality": "npm run check:max-lines && npm run lint && npm run check && npm run test",
    "start": "node dist/cli.js",
    "dev": "ts-node src/cli.ts",
    "smoke:semantic-readability": "bun run scripts/semantic-readability-smoke.ts",
    "smoke:qaoa-figure-4-18": "bun run scripts/figure-4-18-regression.ts",
    "smoke:vqe-figure-4-16": "bun run scripts/figure-4-16-regression.ts",
    "smoke:sa-figure-4-19": "bun run scripts/figure-4-19-regression.ts"
  },
  "keywords": [
    "graphscript",
    "visual-scripting",
    "charts",
    "diagrams",
    "flowchart",
    "algorithm",
    "svg",
    "renderer",
    "browser",
    "frontend",
    "cdn"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@mathjax/src": "^4.1.1",
    "mathjax": "^4.1.1",
    "sharp": "^0.33.2"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "rollup": "^4.60.1",
    "terser": "^5.46.1",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
