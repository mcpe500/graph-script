{
  "name": "graphscript",
  "version": "0.1.0",
  "description": "Composable Visual Scripting for Charts, Diagrams, Algorithms, and 3D",
  "main": "dist/cli.js",
  "bin": {
    "graphscript": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "jest",
    "check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "start": "node dist/cli.js",
    "dev": "ts-node src/cli.ts",
    "smoke:semantic-readability": "bun run scripts/semantic-readability-smoke.ts"
  },
  "keywords": [
    "graphscript",
    "visual-scripting",
    "charts",
    "diagrams",
    "flowchart",
    "algorithm"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@mathjax/src": "^4.1.1",
    "mathjax": "^4.1.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
