{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "outDir": "./dist/browser",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "moduleResolution": "bundler",
    "isolatedModules": true
  },
  "include": [
    "src/platform/**/*",
    "src/tokenizer/**/*",
    "src/parser/**/*",
    "src/ast/**/*",
    "src/runtime/**/*",
    "src/renderer/**/*",
    "src/browser.ts",
    "src/browser/**/*"
  ],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
